# 💻 3. CLI AGENT (PYTHON)

Save as `/agent/main.py`

```python
import csv

class ReflectionAgent:
    def __init__(self, file_path):
        self.nodes = {}
        self.state = {
            "answers": {},
            "signals": {
                "axis1": {"internal": 0, "external": 0},
                "axis2": {"contribution": 0, "entitlement": 0, "mixed": 0},
                "axis3": {"self": 0, "team": 0, "other": 0, "wide": 0}
            }
        }
        self.load_tree(file_path)

    def load_tree(self, file_path):
        with open(file_path, newline='', encoding='utf-8') as f:
            reader = csv.DictReader(f, delimiter='\t')
            for row in reader:
                self.nodes[row['id']] = row

    def get_next(self, node):
        if node["type"] == "decision":
            rules = node["options"].split(";")
            last_answer = list(self.state["answers"].values())[-1]

            for rule in rules:
                cond, target = rule.split(":")
                cond_values = cond.replace("answer=", "").split("|")
                if last_answer in cond_values:
                    return target
        return None

    def apply_signal(self, signal):
        if not signal:
            return
        axis, val = signal.split(":")
        self.state["signals"][axis][val] += 1

    def dominant(self, axis):
        return max(self.state["signals"][axis], key=self.state["signals"][axis].get)

    def run(self):
        current = "START"

        while True:
            node = self.nodes[current]
            print("\n" + node["text"])

            if node["signal"]:
                self.apply_signal(node["signal"])

            if node["type"] == "question":
                options = node["options"].split("|")
                for i, opt in enumerate(options):
                    print(f"{i+1}. {opt}")
                choice = int(input("Choose: ")) - 1
                answer = options[choice]
                self.state["answers"][current] = answer

                # find child
                next_node = None
                for n in self.nodes.values():
                    if n["parentId"] == current:
                        next_node = n["id"]
                        break
                current = next_node

            elif node["type"] == "decision":
                current = self.get_next(node)

            elif node["type"] == "summary":
                text = node["text"]
                text = text.replace("{A1_OPEN.answer}", self.state["answers"].get("A1_OPEN", ""))
                text = text.replace("{axis1.dominant}", self.dominant("axis1"))
                text = text.replace("{axis2.dominant}", self.dominant("axis2"))
                text = text.replace("{axis3.dominant}", self.dominant("axis3"))
                print("\n" + text)

                # move to END
                for n in self.nodes.values():
                    if n["parentId"] == node["id"]:
                        current = n["id"]
                        break

            elif node["type"] == "end":
                print("\nSession complete.")
                break

            else:
                # auto move to child
                next_node = None
                for n in self.nodes.values():
                    if n["parentId"] == current:
                        next_node = n["id"]
                        break
                current = next_node


if __name__ == "__main__":
    agent = ReflectionAgent("../tree/reflection-tree.tsv")
    agent.run()

